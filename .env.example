# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:your-db-password@your-project.supabase.co:5432/postgres

# Content API (for agent/admin write access)
CONTENT_API_KEY=generate-with-openssl-rand-hex-32

# Revalidation (for cache busting after content updates)
REVALIDATION_SECRET=generate-with-openssl-rand-hex-32

# Anthropic (for content generation script)
ANTHROPIC_API_KEY=your-anthropic-api-key
